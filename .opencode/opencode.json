{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@sveltejs/opencode"],
  "mcp": {
    "gsap": {
      "type": "local",
      "command": ["pnpx", "bruzethegreat-gsap-master-mcp-server@latest"]
    },
    "jsrepo": {
      "type": "local",

      "command": ["pnpx", "@jsrepo/mcp"]
    },
    "cloudflare-api": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "pnpx",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    }
  }
}
