{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@sveltejs/opencode", "superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["pnpx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "pnpx",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    }
  }
}
