{
    "name": "frontend",
    "version": "1.9.2",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "start": "next start",
        "build": "next build --debug",
        "build:analyze": "ANALYZE=true yarn run front:build",
        "cypress:open": "start-server-and-test dev 3000 cypress:open:dashboard",
        "cypress:open:dashboard": "cypress open",
        "test": "start-server-and-test dev 3000 cypress:run:headless",
        "cypress:run:headless": "cypress run --config video=false",
        "cypress:test": "start-server-and-test start http://localhost:3000 cypress:run",
        "lint": "yarn eslint '**/*.{js,jsx,ts,tsx}' --resolve-plugins-relative-to .",
        "prettier": "prettier --write '**/*.{js,jsx,ts,tsx}'",
        "release": "standard-version",
        "types": "tsc --noEmit --incremental false",
        "docker:build": "./docker.sh",
        "docker:build:no-cache": "./docker.sh -c",
        "docker:release": "./docker.sh -p",
        "docker:release:no-cache": "./docker.sh -p -c"
    },
    "dependencies": {
        "@next/font": "^13.0.3",
        "@vercel/og": "^0.0.20",
        "classnames": "^2.3.2",
        "cypress-axe": "^1.1.0",
        "highlight.js": "^11.6.0",
        "js-cookie": "^3.0.1",
        "lodash.debounce": "^4.0.8",
        "lodash.throttle": "^4.1.1",
        "next": "^13.0.3",
        "next-seo": "^5.11.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "rehype-document": "^6.1.0",
        "rehype-format": "^4.0.1",
        "rehype-highlight": "^6.0.0",
        "rehype-parse": "^8.0.4",
        "rehype-rewrite": "^3.0.6",
        "rehype-slug": "^5.0.1",
        "rehype-stringify": "^9.0.3",
        "remark": "^14.0.2",
        "remark-frontmatter": "^4.0.1",
        "remark-gfm": "^3.0.1",
        "remark-html": "^15.0.1",
        "remark-parse": "^10.0.1",
        "remark-rehype": "^10.1.0",
        "remark-toc": "^8.0.1",
        "sass": "^1.55.0",
        "sharp": "^0.31.1",
        "start-server-and-test": "^1.14.0",
        "tailwindcss": "3.0.5",
        "typescript": "^4.9.4",
        "unified": "^10.1.2",
        "zustand": "^4.1.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^17.1.2",
        "@commitlint/config-conventional": "^17.1.0",
        "@jsdevtools/rehype-toc": "^3.0.2",
        "@next/bundle-analyzer": "^13.0.0",
        "@react-spring/web": "^9.5.5",
        "@svgr/webpack": "^6.5.1",
        "@testing-library/react": "^11.2.3",
        "@testing-library/react-hooks": "^5.0.0",
        "@types/js-cookie": "^3.0.2",
        "@types/lodash.debounce": "^4.0.7",
        "@types/lodash.throttle": "^4.1.7",
        "@types/node": "^18.11.9",
        "@types/react": "^18.0.24",
        "@types/react-dom": "^18.0.8",
        "@typescript-eslint/eslint-plugin": "^4.9.1",
        "@typescript-eslint/parser": "^4.9.1",
        "autoprefixer": "^10.1.0",
        "cypress": "^11.2.0",
        "dotenv": "^8.2.0",
        "eslint": "^7.15.0",
        "eslint-config-next": "^13.0.3",
        "eslint-config-prettier": "^7.0.0",
        "eslint-plugin-cypress": "^2.12.1",
        "eslint-plugin-prettier": "^3.2.0",
        "husky": "^4.3.7",
        "identity-obj-proxy": "^3.0.0",
        "isomorphic-unfetch": "^3.1.0",
        "lint-staged": "^10.5.3",
        "next-compose-plugins": "^2.2.1",
        "nock": "^13.0.6",
        "postcss": "^8.2.4",
        "postcss-import": "^15.0.0",
        "prettier": "^2.7.1",
        "standard-version": "^9.5.0"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "yarn prettier --config ./.prettierrc.js  --write",
            "yarn eslint --cache --quiet -c ./.eslintrc.js"
        ]
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged"
        }
    }
}
