{
	"name": "dle.dev",
	"version": "1.25.0",
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"release": "standard-version",
		"cf": "yarn build && wrangler pages dev ./.svelte-kit/cloudflare",
		"docker:build": "./docker.sh",
		"docker:build:no-cache": "./docker.sh -c",
		"docker:release": "./docker.sh -p",
		"docker:release:no-cache": "./docker.sh -p -c",
		"test:unit": "vitest --run",
		"test:integration": "playwright test",
		"test:integration:report": "playwright test  && npx playwright show-report",
		"test:integration:ui": "playwright test --ui",
		"test:integration:ci": "playwright test --project=chromium"
	},
	"devDependencies": {
		"@neoconfetti/svelte": "^2.2.1",
		"@playwright/test": "^1.43.0",
		"@skeletonlabs/skeleton": "1.8.0",
		"@sveltejs/adapter-auto": "^3.2.0",
		"@sveltejs/adapter-cloudflare": "^4.2.1",
		"@sveltejs/adapter-cloudflare-workers": "^2.2.1",
		"@sveltejs/adapter-node": "^5.0.1",
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "2.5.5",
		"@sveltejs/vite-plugin-svelte": "^3.0.2",
		"@tailwindcss/forms": "^0.5.7",
		"@types/cookie": "^0.6.0",
		"autoprefixer": "10.4.19",
		"lint-staged": "15.2.2",
		"postcss": "8.4.38",
		"postcss-load-config": "5.0.3",
		"prettier": "3.2.5",
		"prettier-plugin-svelte": "3.2.2",
		"sass": "1.74.1",
		"standard-version": "^9.5.0",
		"svelte": "4.2.12",
		"svelte-check": "3.6.9",
		"svelte-highlight": "^7.6.0",
		"svelte-preprocess": "5.1.3",
		"sveltekit-superforms": "^1.5.0",
		"tailwindcss": "^3.4.3",
		"tslib": "^2.6.2",
		"typescript": "^5.5.2",
		"vite": "5.2.8",
		"vite-tsconfig-paths": "4.3.2",
		"vitest": "^1.4.0",
		"zod": "^3.22.4",
		"@typescript-eslint/eslint-plugin": "^7.5.0",
		"@typescript-eslint/parser": "^7.5.0",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-simple-import-sort": "^12.0.0",
		"eslint-plugin-svelte": "^2.35.1",
		"eslint-plugin-unused-imports": "^3.1.0"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/lato": "5.0.20",
		"@fontsource/merriweather": "^5.0.12",
		"@jsdevtools/rehype-toc": "^3.0.2",
		"@types/js-cookie": "^3.0.6",
		"classnames": "2.5.1",
		"dayjs": "^1.11.10",
		"dotenv": "^16.4.5",
		"highlight.js": "^11.9.0",
		"js-cookie": "^3.0.5",
		"just-debounce-it": "^3.2.0",
		"octokit": "^3.2.0",
		"rehype": "13.0.1",
		"swiper": "^11.1.0",
		"wrangler": "^3.48.0",
		"rehype-document": "^6.1.0",
		"rehype-format": "^4.0.1",
		"rehype-highlight": "^6.0.0",
		"rehype-rewrite": "^3.0.6",
		"rehype-slug": "^5.1.0",
		"rehype-stringify": "^9.0.3",
		"remark-gfm": "^3.0.1",
		"remark-parse": "^10.0.1",
		"remark-rehype": "^10.1.0",
		"unified": "^10.1.2"
	}
}
