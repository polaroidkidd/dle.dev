{
  "name": "dle.dev",
  "private": true,
  "version": "1.4.2",
  "scripts": {
    "dev:back": "yarn workspace backend back:dev",
    "dev:front": "yarn workspace frontend front:dev",
    "dev": "concurrently \"yarn dev:back\" \"yarn dev:front\"",
    "lint": "yarn eslint '**/*.{js,jsx,ts,tsx}' --resolve-plugins-relative-to .",
    "prettier": "prettier --write '**/*.{js,jsx,ts,tsx}'",
    "prepare": "husky install",
    "release": "standard-version",
    "docker:build:frontend": "./docker.sh -m frontend",
    "docker:build:frontend:no-cache": "./docker.sh -m frontend -c",
    "docker:release:frontend": "./docker.sh -m frontend -p",
    "docker:release:frontend:no-cache": "./docker.sh -m frontend -p -c"
  },
  "homepage": "https://dle.dev",
  "workspaces": [
    "./packages/frontend"
  ],
  "devDependencies": {
    "@next/eslint-plugin-next": "^12.3.1",
    "@trivago/prettier-plugin-sort-imports": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "eslint": "^7.15.0",
    "eslint-config-next": "^12.3.0",
    "eslint-config-prettier": "^7.0.0",
    "eslint-plugin-prettier": "^3.2.0",
    "husky": "^8.0.1",
    "lint-staged": "^10.5.3",
    "prettier": "^2.7.1",
    "tailwindcss": "3.0.5",
    "typescript": "^4.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "yarn prettier --config ./.prettierrc.js  --write",
      "yarn eslint --cache --quiet -c ./.eslintrc.js"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@types/jest": "^29.0.0",
    "concurrently": "^7.5.0",
    "standard-version": "^9.5.0"
  },
  "resolutions": {
    "graphql": "16.6.0"
  }
}
