{
	"name": "dle.dev",
	"version": "1.25.0",
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"release": "standard-version",
		"cf": "yarn build && wrangler pages dev ./.svelte-kit/cloudflare",
		"docker:build": "./docker.sh",
		"docker:build:no-cache": "./docker.sh -c",
		"docker:release": "./docker.sh -p",
		"docker:release:no-cache": "./docker.sh -p -c",
		"test:unit": "vitest --run",
		"test:integration": "playwright test",
		"test:integration:report": "playwright test  && npx playwright show-report",
		"test:integration:ui": "playwright test --ui",
		"test:integration:ci": "playwright test --project=chromium"
	},
	"devDependencies": {
		"@neoconfetti/svelte": "^1.0.0",
		"@playwright/test": "^1.37.1",
		"@skeletonlabs/skeleton": "1.8.0",
		"@sveltejs/adapter-auto": "^2.0.0",
		"@sveltejs/adapter-cloudflare": "^2.3.1",
		"@sveltejs/adapter-cloudflare-workers": "^1.1.2",
		"@sveltejs/adapter-node": "^1.2.3",
		"@sveltejs/adapter-static": "^2.0.2",
		"@sveltejs/kit": "1.22.3",
		"@tailwindcss/forms": "^0.5.3",
		"@types/cookie": "^0.5.1",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"autoprefixer": "10.4.14",
		"eslint": "^8.45.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-svelte": "^2.32.2",
		"lint-staged": "13.2.3",
		"postcss": "8.4.21",
		"postcss-load-config": "4.0.1",
		"prettier": "3.0.0",
		"prettier-plugin-svelte": "3.0.0",
		"sass": "1.64.1",
		"standard-version": "^9.5.0",
		"svelte": "4.1.1",
		"svelte-check": "3.4.6",
		"svelte-highlight": "^7.3.0",
		"svelte-preprocess": "5.0.4",
		"sveltekit-superforms": "^1.5.0",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.6.0",
		"typescript": "^5.1.6",
		"vite": "4.4.4",
		"vite-tsconfig-paths": "4.2.0",
		"vitest": "^0.25.3",
		"zod": "^3.21.4"
	},
	"type": "module",
	"dependencies": {
		"@fontsource/lato": "5.0.5",
		"@fontsource/merriweather": "^4.5.14",
		"@jsdevtools/rehype-toc": "^3.0.2",
		"@types/js-cookie": "^3.0.3",
		"classnames": "2.3.2",
		"dayjs": "^1.11.9",
		"dotenv": "^16.3.1",
		"rehype": "12.0.1",
		"highlight.js": "^11.8.0",
		"js-cookie": "^3.0.1",
		"just-debounce-it": "^3.2.0",
		"octokit": "^3.0.0",
		"rehype-document": "^6.1.0",
		"rehype-format": "^4.0.1",
		"rehype-highlight": "^6.0.0",
		"rehype-rewrite": "^3.0.6",
		"rehype-slug": "^5.1.0",
		"rehype-stringify": "^9.0.3",
		"remark-gfm": "^3.0.1",
		"remark-parse": "^10.0.1",
		"remark-rehype": "^10.1.0",
		"swiper": "^10.0.4",
		"unified": "^10.1.2",
		"wrangler": "^3.3.0"
	}
}
