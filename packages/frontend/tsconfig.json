{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@model/*": ["./src/model/*"],
      "@components/*":["./src/components/*"],
      "@icons/*":["./src/components/icons/*"],
      "@lib/*": ["./src/lib/*"],
      "@pages/*":["./src/pages/*"],
      "@services/*": ["./src/services/*"],
      "@styles/*":["./src/styles/*"],
      "@utils/*": ["./src/utils/*"],
      "@public/*": ["./public/*"]
    },
    "incremental": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "__generated__/globalTypes.ts", "test/*", "cypress/*"]
}
